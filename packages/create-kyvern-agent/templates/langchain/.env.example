# ─── Kyvern vault wiring ───
# Fill these in after creating a vault at https://kyvernlabs.com/vault/new
# (or by running `npx tsx scripts/demo-e2e.ts` in the kyvernlabs monorepo).

# Solana cluster the vault lives on. "devnet" or "mainnet".
KYVERN_CLUSTER=devnet

# Solana RPC. Helius/Triton/QuickNode work too.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Squads v4 multisig PDA for your vault.
KYVERN_MULTISIG=

# Squads spending limit PDA delegated to this agent.
KYVERN_SPENDING_LIMIT=

# Agent keypair secret (base58). The vault's /vault/new success page shows
# this ONCE — store it here and don't commit it.
KYVERN_AGENT_KEY=

# Where to send test payments. Any Solana wallet works.
RECIPIENT_WALLET=

# Merchant hostname on the vault's allowlist (used in the ALLOWED call).
ALLOWED_MERCHANT=merchant.example.com
