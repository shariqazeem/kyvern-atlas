# ─── Kyvern vault wiring ───
# Mint the agent key from https://kyvernlabs.com/app · "Agent keys" · Mint a key.
# Shown once — paste it here.

KYVERN_AGENT_KEY=

# Optional. Defaults to https://kyvernlabs.com.
# Set to http://localhost:3001 if you're running Kyvern locally.
# KYVERN_BASE_URL=https://kyvernlabs.com


# ─── Pay.sh integration ───
# The default sample agent shells out to the pay.sh CLI to demonstrate
# wrapping any 402-paywalled HTTP API in your Kyvern vault budget.
# Install:  brew install pay   (macOS)
#       OR  npm install -g @solana/pay   (Linux/Windows)
# More:     https://pay.sh

# Optional. The demo URL the sample fires at via `pay --sandbox curl`.
# Default is the AAPL quote endpoint — sandbox uses an ephemeral wallet
# so no real money moves at the pay.sh layer (the on-chain spend is
# real and budgeted by Kyvern).
# PAYSH_DEMO_URL=https://debugger.pay.sh/mpp/quote/AAPL


# ─── KAST-funded card payout (optional) ───
# Open the KAST app · Deposit · Solana USDC · copy the address.
# When set, the sample's step 3 routes a $0.10 share to your KAST card.
# Don't have a KAST card?  https://go.kast.xyz/VqVO/STPAK

# MY_KAST_ADDRESS=
