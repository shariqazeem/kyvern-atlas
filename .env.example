# KyvernLabs — Environment Variables
# Copy this file to .env.local and fill in your values

# === Required for x402 services ===

# Wallet address that receives x402 payments (your wallet)
X402_PAYTO_ADDRESS=0xYOUR_WALLET_ADDRESS

# Private key for the demo buyer wallet (used by "Make Live Payment" button)
# WARNING: Use a testnet-only wallet. Never put real funds in this wallet.
X402_CLIENT_PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY

# === x402 Protocol ===

# Facilitator URL (free testnet, no API key needed)
X402_FACILITATOR_URL=https://x402.org/facilitator

# Network identifier (CAIP-2 format)
# Base (mainnet): eip155:8453
# Base Sepolia (testnet): eip155:84532
X402_NETWORK=eip155:8453

# === Pulse Config ===

# Default API key for demo endpoint
PULSE_API_KEY=demo_key_001

# Base URL for your deployment
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Pay-to address shown in the UI (defaults to X402_PAYTO_ADDRESS)
NEXT_PUBLIC_PAY_TO_ADDRESS=0xYOUR_WALLET_ADDRESS

# SQLite database path (default: ./pulse.db)
# PULSE_DB_PATH=./pulse.db

# === Stellar Testnet (for Stellar Hacks hackathon) ===
# Generate via: POST /api/x402/stellar-demo (auto-creates + funds via Friendbot)
# STELLAR_TESTNET_SECRET=Sxxxxxx... (56 chars, starts with S)
# STELLAR_TESTNET_PUBLIC=Gxxxxxx... (56 chars, starts with G)

# === Privy Auth ===
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# === AI Copilot (optional) ===
# LLM provider for Copilot: "heuristic" (default, free), "elsa", "openai", "anthropic"
# LLM_PROVIDER=heuristic

# Elsa LLM Gateway (if LLM_PROVIDER=elsa)
# ELSA_GATEWAY_URL=https://gateway.elsa.ai/v1
# ELSA_API_KEY=your_elsa_api_key
